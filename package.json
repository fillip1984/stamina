{
  "name": "stamina-monorepo",
  "private": true,
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=10.29.1"
  },
  "packageManager": "pnpm@10.29.1",
  "scripts": {
    "auth:generate": "pnpm -F @stamina/auth generate",
    "build": "pnpm -r build",
    "build:mobile": "pnpm -F !web run build:production",
    "build:packages": "pnpm -F './packages/**' run build",
    "build:web": "pnpm -F \"!@stamina/mobile\" run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "pnpm -r clean",
    "db:export": "pnpm -F @stamina/db export",
    "db:push": "pnpm -F @stamina/db push",
    "db:studio": "pnpm -F @stamina/db studio",
    "db:upgrade": "pnpm -F @stamina/db upgrade",
    "dev": "pnpm -r run dev",
    "format": "pnpm -r format",
    "format:fix": "pnpm -r format",
    "ios": "pnpm -F mobile run ios",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint",
    "lint:ws": "pnpm dlx sherif@latest",
    "preinstall": "npx only-allow pnpm",
    "prod:db:push": "pnpm -F @stamina/db push:prod",
    "prod:deploy": "pnpm dotenv -e .env.prod -- sst deploy --stage prod",
    "prod:nuke": "pnpm dotenv -e .env.prod -- sst remove --stage prod",
    "typecheck": "pnpm -r typecheck",
    "update-all": "pnpm -r update --latest"
  },
  "devDependencies": {
    "@stamina/prettier-config": "workspace:*",
    "@types/aws-lambda": "8.10.161",
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "prettier": "@stamina/prettier-config",
  "dependencies": {
    "sst": "4.5.12"
  }
}
