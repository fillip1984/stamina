{
  "name": "@stamina/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm lint",
    "build:interactive": "pnpm lint && pnpm with-env eas build -p ios -e production --local",
    "build:production": "pnpm lint && pnpm with-env eas build -p ios -e production --local --non-interactive",
    "clean": "git clean -xdf .cache .expo  android ios node_modules",
    "ios": "expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "android": "expo run:android"
  },
  "dependencies": {
    "@better-auth/expo": "^1.4.18",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@stamina/api": "workspace:*",
    "@stamina/db": "workspace:*",
    "@tanstack/react-query": "^5.95.2",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.22",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.11",
    "expo-image": "~55.0.8",
    "expo-linking": "~55.0.11",
    "expo-network": "55.0.11",
    "expo-router": "~55.0.10",
    "expo-secure-store": "^55.0.11",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.13",
    "expo-web-browser": "~55.0.12",
    "nativewind": "5.0.0-preview.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-animated-spinkit": "^1.5.2",
    "react-native-css": "^3.0.1",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-worklets": "~0.7.2",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@stamina/eslint-config": "workspace:*",
    "@stamina/prettier-config": "workspace:*",
    "@stamina/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "19.2.14",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~55.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "prettier": "@stamina/prettier-config"
