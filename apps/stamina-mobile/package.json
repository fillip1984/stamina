{
  "name": "@stamina/mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm lint",
    "build:interactive": "pnpm lint && pnpm with-env eas build -p ios -e production --local",
    "build:production": "pnpm lint && pnpm with-env eas build -p ios -e production --local --non-interactive",
    "clean": "git clean -xdf .cache .expo  android ios node_modules",
    "ios": "expo run:ios",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "android": "expo run:android"
  },
  "dependencies": {
    "@better-auth/expo": "^1.4.18",
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.2.2",
    "@stamina/api": "workspace:*",
    "@stamina/db": "workspace:*",
    "@tanstack/react-query": "^5.95.2",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@trpc/tanstack-react-query": "^11.16.0",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~54.0.32",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.22",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "nativewind": "5.0.0-preview.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-animated-spinkit": "^1.5.2",
    "react-native-css": "^3.0.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "~0.5.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@stamina/eslint-config": "workspace:*",
    "@stamina/prettier-config": "workspace:*",
    "@stamina/tsconfig": "workspace:*",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "19.1.17",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~10.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "prettier": "@stamina/prettier-config"
}
